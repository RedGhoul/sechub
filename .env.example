# --- SecHub configuration ---

# REQUIRED by the SEC: a descriptive User-Agent with real contact info.
# Requests without this can be throttled or blocked. Format: "AppName email".
SECHUB_USER_AGENT=SecHub/0.1 (you@example.com)

# Postgres connection (defaults match docker-compose).
DATABASE_URL=postgresql+psycopg://sechub:sechub@db:5432/sechub

# Real-time feed poll interval (seconds) and the UTC hour (0-23) for the
# worker's once-a-day daily-index catch-up backfill.
SECHUB_POLL_INTERVAL=120
SECHUB_BACKFILL_HOUR=5

# Hard cap on EDGAR requests per second (SEC limit is 10). Keep ≤ 10.
SECHUB_MAX_RPS=8

# Comma-separated form types the worker watches on the real-time feed.
SECHUB_WATCH_FORMS=13F-HR,4,SC 13D,SC 13G,NPORT-P

# Frontend → API base URL (used by the Next.js app).
NEXT_PUBLIC_API_BASE=http://localhost:8000
